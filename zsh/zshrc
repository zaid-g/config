function ARE() {
    if [[ $# -ne 1 ]]; then
        echo "Error: ARE requires exactly one argument (path)" >&2
        return 1
    fi
    
    if [[ ! -e "$1" ]]; then
        echo "Error: Path '$1' does not exist" >&2
        return 1
    fi
    
    local brain_parent_path
    brain_parent_path=$(FIND_BRAIN_PARENT_PATH) || return 1
    local full_file_path=$(readlink -f "$1")
    local temp_file_path=$(mktemp)
    
    # Add existing paths and new path to temp file, then sort unique
    if [[ -f "$brain_parent_path/brain/related.txt" ]]; then
        cat "$brain_parent_path/brain/related.txt" > "$temp_file_path"
    fi
    echo "$full_file_path" >> "$temp_file_path"
    
    # Remove duplicates and save back
    sort -u "$temp_file_path" > "$brain_parent_path/brain/related.txt"
    rm "$temp_file_path"
}

#  %% -------- [zsh hooks] ----------:

function ECHO_PREEXEC_COMMANDS() {
    echo $___COMMAND_TYPED
    echo $___COMMAND_ONELINE
    echo $___COMMAND_MULTILINE
}

function DEDUP_COMMAND_HISTORY() {
    local brain_parent_path=$(FIND_BRAIN_PARENT_PATH 2>/dev/null)
    local command_history_file_path="$brain_parent_path/brain/command_history.txt"
    [[ -z $brain_parent_path || ! -f $command_history_file_path || ! -s $command_history_file_path ]] && return
    awk '
        BEGIN { RS=""; ORS="\n\n" }
        { blocks[NR] = $0 }
        END { for (i=NR; i>=1; i--) print blocks[i] }
    ' "$command_history_file_path" | awk -v threshold="$___COMMAND_DURATION_LOGGING_THRESHOLD" '
        BEGIN { RS=""; ORS="\n\n" }
        {
            split($0, lines, "\n")
            split(lines[6], t, ":")
            secs = t[1]*3600 + t[2]*60 + t[3]
            if (secs > threshold) { print; next }
            key = lines[1] SUBSEP lines[2]
            if (!(key in seen)) { seen[key]; print }
        }
    ' | awk '
        BEGIN { RS=""; ORS="\n\n" }
        { blocks[NR] = $0 }
        END { for (i=NR; i>=1; i--) print blocks[i] }
    ' > "$command_history_file_path.tmp" && mv "$command_history_file_path.tmp" "$command_history_file_path"
}

function preexec() {
    # dedup command history
    DEDUP_COMMAND_HISTORY
    # flag to see if preexec ran
    ___PREEXEC_RAN_FOR_USER_ENTRY=true
    # what user inputted and from where
    ___COMMAND_TYPED="$1"
    ___COMMAND_ONELINE="$2"
    ___COMMAND_MULTILINE="$3"
    ___COMMAND_FORMATTED="${3//$'\r'/}"
    ___COMMAND_FORMATTED="${___COMMAND_FORMATTED//$'\n'/; }"
    ___COMMAND_PATH="$PWD"
    # datetime calculations
    ___COMMAND_START_EPOCH_SECONDS=$(date +%s)
    ___COMMAND_START_DATETIME=$(date '+%Y-%m-%d %H:%M:%S')
}

function precmd() {
    ___COMMAND_EXIT_CODE=$?
    # break if user entry didn't trigger preexec
    # e.g. user inputted enter without anything
    # or pure whitespace
    [[ -z $___PREEXEC_RAN_FOR_USER_ENTRY ]] && return
    ___PREEXEC_RAN_FOR_USER_ENTRY=""
    # compute timings
    ___COMMAND_END_EPOCH_SECONDS=$(date +%s)
    ___COMMAND_END_DATETIME=$(date '+%Y-%m-%d %H:%M:%S')
    ___COMMAND_ELAPSED=$(( ___COMMAND_END_EPOCH_SECONDS - ___COMMAND_START_EPOCH_SECONDS ))
    ___COMMAND_DURATION=$(printf '%02d:%02d:%02d' $((___COMMAND_ELAPSED/3600)) $((___COMMAND_ELAPSED%3600/60)) $((___COMMAND_ELAPSED%60)))
    # print execution time
    (( ___COMMAND_ELAPSED >= ___COMMAND_DURATION_LOGGING_THRESHOLD )) && echo "\n - Time: $___COMMAND_DURATION ($___COMMAND_START_DATETIME → $___COMMAND_END_DATETIME)\n"
    # log in command history file
    local brain_parent_path=$(FIND_BRAIN_PARENT_PATH 2>/dev/null)
    local command_history_file_path="$brain_parent_path/brain/command_history.txt"
    if [[ -n $brain_parent_path && -f $command_history_file_path && -n $___COMMAND_FORMATTED ]]; then
        printf '%s\n%s\nexit:%s\n%s\n%s\n%s\n\n' \
            "$___COMMAND_FORMATTED" "$___COMMAND_PATH" "$___COMMAND_EXIT_CODE" "$___COMMAND_START_DATETIME" "$___COMMAND_END_DATETIME" "$___COMMAND_DURATION" >> "$command_history_file_path"
    fi
    local command_history_full_file_path="$brain_parent_path/brain/command_history_full.txt"
    if [[ -n $brain_parent_path && -f $command_history_full_file_path && -n $___COMMAND_FORMATTED ]]; then
        printf '%s\n%s\nexit:%s\n%s\n%s\n%s\n\n' \
            "$___COMMAND_FORMATTED" "$___COMMAND_PATH" "$___COMMAND_EXIT_CODE" "$___COMMAND_START_DATETIME" "$___COMMAND_END_DATETIME" "$___COMMAND_DURATION" >> "$command_history_full_file_path"
    fi
}

function chpwd() {
    setopt NO_WARN_CREATE_GLOBAL
    local cwd_basename="${PWD:t}"
    [[ -z "$cwd_basename" ]] && return  # Skip if at root or empty
    local venv_path="$HOME/.virtualenvs/.$cwd_basename"
    if [[ -d "$venv_path" && "$VIRTUAL_ENV" != "$venv_path" ]]; then
        [[ -n "$VIRTUAL_ENV" ]] && deactivate
        # activate the associated venv. Keep it active even if leaving
        # to e.g. subdirectory (intentional)
        source "$venv_path/bin/activate"
    fi
    if [[ -n "$TMUX" ]] && [[ "$(tmux show-options -w -t $TMUX_PANE @AUTORENAME 2>/dev/null | grep -o '0$')" != "0" ]]; then
        TMUX_RENAME_WINDOW
    fi
}

