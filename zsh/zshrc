# tmux commands continue in new(ly focused) splits/windows
# but shell commands continue in calling pane
# the trick is to never send keys to trigger a function
# that calls tmux commands and later trigger tmux commands
# (the send keys is asynchronous and tmux changes state before
# the nested tmux commands execute) unless the downstream calls
# know how to target the right panes.
function TOD() {
    local target_pane_id="$TMUX_PANE"
    tmux send-keys -t "$target_pane_id" 'CDJ' Enter
    target_pane_id=$(tmux new-window -P -F '#{pane_id}')
    tmux send-keys -t "$target_pane_id" 'TON' Enter
    target_pane_id=$(tmux new-window -P -F '#{pane_id}')
    tmux send-keys -t "$target_pane_id" 'TOJ' Enter
    target_pane_id=$(tmux new-window -P -F '#{pane_id}')
    tmux send-keys -t "$target_pane_id" 'TOAI' Enter
    target_pane_id=$(tmux new-window -P -F '#{pane_id}')
    tmux send-keys -t "$target_pane_id" 'TOC' Enter
}

function TON() {
    local target_pane_id="$TMUX_PANE"
