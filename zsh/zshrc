function GET_GITIGNORE_PATTERNS() {
    local gitignore_file="$HOME/doc/config/config/git/gitignore"
    if [[ ! -f "$gitignore_file" ]]; then
        echo "Error: gitignore file not found at $gitignore_file" >&2
        return 1
    fi
    local patterns=()
    local line
    while IFS= read -r line; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" == \#* ]] && continue
        # Strip trailing slashes (directory markers)
        line="${line%/}"
        patterns+=("$line")
    done < "$gitignore_file"
    printf '%s\n' "${patterns[@]}"
}

function FIND_ALL_NON_IGNORED_FILES() {
    local ignored_folder_patterns=("${GITIGNORE_PATTERNS[@]}")
    local find_cmd=(find .)
    local pattern
    for pattern in "${ignored_folder_patterns[@]}"; do
        find_cmd+=(-path "*/$pattern" -prune -o)
    done
    find_cmd+=(-type f -print)
    "${find_cmd[@]}"
}

# Function to find files matching given extensions
function FIND_NON_IGNORED_FILE_PATHS_MATCHING_TYPES() {
    local file_extensions=("$@")
    local found_file_paths=$(FIND_ALL_NON_IGNORED_FILES)
    # If extensions are given, filter by them (case-insensitive)
    if [ "${#file_extensions[@]}" -gt 0 ]; then
        local pattern=$(IFS=\|; echo "${file_extensions[*]}" | sed 's/ /|/gI')
        echo "$found_file_paths" | grep -Eiq "\.(${pattern})$" && echo "$found_file_paths" | grep -Ei "\.(${pattern})$" | sort || return
    else
        echo "$found_file_paths" | sort
    fi
}

# Function to find files matching a general pattern
function FIND_FILES_MATCHING_PATTERN() {
    local pattern="$1"
    local found_file_paths=$(FIND_ALL_NON_IGNORED_FILES)
    # If a pattern is given, filter by it (case-insensitive)
    if [ -n "$pattern" ]; then
        echo "$found_file_paths" | grep -Eiq "$pattern" && echo "$found_file_paths" | grep -Ei "$pattern" | sort || return
    else
        echo "$found_file_paths" | sort
    fi
}

function FINDT() {
    echo
    FIND_NON_IGNORED_FILE_PATHS_MATCHING_TYPES "$@"
}

function FIND() {
    echo
    FIND_FILES_MATCHING_PATTERN "$@"
}

function GREP() {
    echo
    local file_path
    if [ "$#" -eq 1 ]; then
        local pattern="$1"
        local found_file_paths=$(FIND_NON_IGNORED_FILE_PATHS_MATCHING_TYPES)
    else
        local pattern="${@: -1}"
        local exts=("${@:1:$#-1}")
        local found_file_paths=$(FIND_NON_IGNORED_FILE_PATHS_MATCHING_TYPES "${exts[@]}")
    fi
    [ -z "$found_file_paths" ] && return
    while IFS= read -r file_path; do
        "$GNU_GREP" -Hni -e "$pattern" "$file_path"
    done <<< "$found_file_paths"
}

