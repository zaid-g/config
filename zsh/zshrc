# """ Note:
# tmux commands continue in new(ly focused) splits/windows
# but shell commands continue in calling pane
# the trick is to never send keys to trigger a function
# that calls tmux commands and later trigger tmux commands
# (the send keys is asynchronous and tmux changes state before
# the nested tmux commands execute) unless the downstream calls
# know how to target the right panes.
# """

function TAS() {
    if [[ -n "$1" ]]; then
        tmux attach-session -t "$1"
        return
    fi
    local tmux_session_count=$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$tmux_session_count" -eq 1 ]]; then
        tmux attach-session
    elif [[ "$tmux_session_count" -gt 1 ]]; then
        echo "Specify session:"
        tmux list-sessions
        return 1
    else
        echo "No tmux sessions"
    fi
}

function TKS() {
    if [[ -n "$1" ]]; then
        tmux kill-session -t "$1"
        return
    fi
    local tmux_session_count=$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$tmux_session_count" -eq 1 ]]; then
        tmux kill-session
    elif [[ "$tmux_session_count" -gt 1 ]]; then
        echo "Specify session:"
        tmux list-sessions
        return 1
    else
        echo "No tmux sessions"
    fi
}

function NOTAR(){
    tmux set-window-option -t $TMUX_PANE @AUTORENAME 0
}

function TAR(){
    tmux set-window-option -u -t $TMUX_PANE @AUTORENAME
}

function TMUX_SWAP_WINDOW_PREV() {
    local current_window_index=$(tmux display-message -p '#{window_index}')
    [[ "$current_window_index" -gt 0 ]] && tmux swap-window -t -1 \; select-window -t -1 || true
}

function TMUX_SWAP_WINDOW_NEXT() {
    local current_window_index=$(tmux display-message -p '#{window_index}')
    local last_window_index=$(tmux list-windows -F '#{window_index}' | tail -1)
    [[ "$current_window_index" -lt "$last_window_index" ]] && tmux swap-window -t +1 \; select-window -t +1 || true
}

function TMUX_RENAME_WINDOW() {
    [[ "$PWD" == "/" ]] && return
    local window_name
    window_name=$(FIND_BRAIN_PARENT_NAME 2>/dev/null) || window_name=$(basename "$PWD")
    [[ ${#window_name} -gt 15 ]] && window_name="${window_name:0:12}…"
    tmux rename-window -t "$TMUX_PANE" "$window_name"
}

