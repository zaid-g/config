# find files by extension (or all files if no args)
function FD() {
    if [ "$#" -eq 0 ]; then
        fd --type f
    else
        local ext ext_flags=()
        for ext in "$@"; do
            ext_flags+=("-e" "$ext")
        done
        fd "${ext_flags[@]}"
