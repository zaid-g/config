# tmux open brain parent
function TOBP() {
    if [[ $# -gt 1 ]] || [[ $# -eq 1 && ! "$1" =~ ^[0-9]+$ ]] || [[ $# -eq 1 && "$1" -ge 5 ]]; then
        echo "Usage: TOBP [1-4]" >&2
        return 1
    fi
    CDBP || return 1
    local target_pane_id="$TMUX_PANE"
    tmux send-keys -t "$target_pane_id" 'TTAR' Enter
    tmux send-keys -t "$target_pane_id" 'KKR' Enter
    target_pane_id=$(tmux split-window -h -t "$target_pane_id" -P -F '#{pane_id}')
    tmux send-keys -t "$target_pane_id" 'VB' Enter
    tmux split-window -v -t "$target_pane_id"
    local count=${1:-1}
    for ((i = 2; i <= count; i++)); do
        target_pane_id=$(tmux new-window -P -F '#{pane_id}')
        tmux send-keys -t "$target_pane_id" 'CDBP' Enter
        tmux send-keys -t "$target_pane_id" 'TTAR' Enter
    done
}

# tmux create brain parent
function TCBP() {
    local target_pane_id
    target_pane_id=$(tmux new-window -P -F '#{pane_id}')
    tmux send-keys -t "$target_pane_id" "MKJ $*" Enter
    tmux send-keys -t "$target_pane_id" "TB" Enter
    [[ "$IS_DEV_MACHINE" == "true" ]] && tmux send-keys -t "$target_pane_id" "TH" Enter
    tmux send-keys -t "$target_pane_id" "TOBP" Enter
}

