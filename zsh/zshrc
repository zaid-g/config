    read "msg?Amend message: "
    [[ -z "$msg" ]] && { echo "Message required"; return 1; }
    if [[ $# -eq 0 ]]; then
        git commit --amend -m "$msg"
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            git -C "$file_path" commit --amend -m "$msg"
        done
    fi
}

function GL() {
    if [[ $# -eq 0 ]]; then
        echo "\n\n" && git --no-pager log --graph --decorate --oneline -8
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            git -C "$file_path" --no-pager log --graph --decorate --oneline -8
        done
    fi
}

function GI() {
    if [[ $# -eq 0 ]]; then
        if [[ ! -d .git ]]; then
            git init
        else
            echo "Git repository already exists"
        fi
        [[ ! -f .gitignore ]] && cp ~/doc/config/config/git/gitignore .gitignore
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            git -C "$file_path" init
            [[ ! -f "$file_path/.gitignore" ]] && cp ~/doc/config/config/git/gitignore "$file_path/.gitignore"
        done
    fi
}

function GIG() {
    [[ -z "$1" ]] && { echo "Usage: GIG <path>"; return 1; }
    [[ ! -d .git ]] && { echo "Not a git repository"; return 1; }
    [[ ! -f .gitignore ]] && touch .gitignore
    grep -Fxq "$1" .gitignore || echo "$1" >> .gitignore
}

function GAC() {
    local msg
    read "msg?Commit message (enter for timestamp): "
    [[ -z "$msg" ]] && msg="$(date '+%Y-%m-%d %H:%M:%S')"
    if [[ $# -eq 0 ]]; then
        git add . && git commit -m "$msg"
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            git -C "$file_path" add . && git -C "$file_path" commit -m "$msg"
        done
    fi
}

function GDBP() {
    local brain_parent_path
    brain_parent_path=$(FIND_BRAIN_PARENT_PATH) || return 1
    git -C "$brain_parent_path" diff
}

function GSBP() {
    local brain_parent_path
    brain_parent_path=$(FIND_BRAIN_PARENT_PATH) || return 1
    git -C "$brain_parent_path" status
}

function GCBP() {
    local brain_parent_path
    brain_parent_path=$(FIND_BRAIN_PARENT_PATH) || return 1
    git -C "$brain_parent_path" add . && git -C "$brain_parent_path" commit -m 'F'
}

function GDIFF() {
    git rev-parse --git-dir >/dev/null 2>&1 || { echo "Not a git repo"; return 1; }
    local tmpfile=$(mktemp) file
    git diff "$@" >> "$tmpfile"
    if [[ $# -eq 0 ]]; then
        git ls-files --others --exclude-standard | while read -r file; do
            git diff --no-index /dev/null "$file" >> "$tmpfile"
        done
    fi
    cat "$tmpfile" | delta --side-by-side --line-numbers
    rm "$tmpfile"
}

function GSQUASH() {
    if [[ $# -ne 2 ]]; then
        echo "Usage: GSQUASH <commit_hash> <commit_message>"
        return 1
    fi
    local commit_hash="$1"
    local commit_message="$2"
    if ! git rev-parse --verify "$commit_hash" >/dev/null 2>&1; then
        echo "Error: Invalid commit hash"
        return 1
    fi
    git reset --soft "$commit_hash" && git commit -m "$commit_message"
}

function GSTASH() {
    local msg="${*:-"WIP stash"}"
    git stash push -u -m "$msg"
}

