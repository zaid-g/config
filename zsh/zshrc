# GSTASH creates a marker file before stashing to guarantee a stash entry
# even on clean repos. This prevents GSTASHPOP from accidentally popping
# an older unrelated stash when running across multiple packages.
function GSTASH() {
    local msg file_path
    read "msg?Stash message (enter for WIP): "
    [[ -z "$msg" ]] && msg="WIP stash"
    if [[ $# -eq 0 ]]; then
        local git_repo_root_path
        git_repo_root_path=$(git rev-parse --show-toplevel) || return 1
        touch "$git_repo_root_path/$GIT_STASH_FLAG_FILE" || { echo "Error: cannot create flag file"; return 1; }
        git stash push -u -m "$msg" || rm -f "$git_repo_root_path/$GIT_STASH_FLAG_FILE"
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            local git_repo_root_path
            git_repo_root_path=$(git -C "$file_path" rev-parse --show-toplevel) || continue
            touch "$git_repo_root_path/$GIT_STASH_FLAG_FILE" || { echo "Error: cannot create flag file"; continue; }
            git -C "$file_path" stash push -u -m "$msg" || rm -f "$git_repo_root_path/$GIT_STASH_FLAG_FILE"
        done
    fi
}

function GSTASHPOP() {
    local file_path
    if [[ $# -eq 0 ]]; then
        local git_repo_root_path
        git_repo_root_path=$(git rev-parse --show-toplevel) || return 1
        git stash pop -q && { echo "Popped"; rm -f "$git_repo_root_path/$GIT_STASH_FLAG_FILE"; }
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            local git_repo_root_path
            git_repo_root_path=$(git -C "$file_path" rev-parse --show-toplevel) || continue
            git -C "$file_path" stash pop -q && { echo "Popped"; rm -f "$git_repo_root_path/$GIT_STASH_FLAG_FILE"; }
        done
    fi
}

