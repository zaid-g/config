function GCH() {
    local branch
    read "branch?Branch: "
    [[ -z "$branch" ]] && { echo "Branch required"; return 1; }
    if [[ $# -eq 0 ]]; then
        git checkout "$branch"
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            git -C "$file_path" checkout "$branch"
        done
    fi
}

function GC() {
    local msg
    read "msg?Commit message: "
    [[ -z "$msg" ]] && { echo "Message required"; return 1; }
    if [[ $# -eq 0 ]]; then
        git commit -m "$msg"
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            git -C "$file_path" commit -m "$msg"
        done
    fi
}

function GB() {
    if [[ $# -eq 0 ]]; then
        git branch --sort=-committerdate
    else
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            git -C "$file_path" branch --sort=-committerdate
        done
    fi
}

