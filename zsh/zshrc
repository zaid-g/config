function RESOLVE_GIT_BRANCH_OR_COMMIT() {
    local ref branch_name_that_matches commit_hash_that_matches
    read "ref?Diff against (enter for working tree): "
    [[ -z "$ref" ]] && { echo ""; return 0; }
    if git rev-parse --verify "$ref^{commit}" >/dev/null 2>&1; then
        echo "$ref"; return 0
    fi
    local branch_names_that_match=($(git branch --list "*$ref*" --format='%(refname:short)'))
    local commit_hashes_that_match=($(git log --all --oneline 2>/dev/null | awk '{print $1}' | grep "^$ref"))
    local options=()
    echo "No exact match. Options:" >&2
    local i=1
    for branch_name_that_matches in "${branch_names_that_match[@]}"; do
        echo "  $i) [branch] $branch_name_that_matches" >&2
        options+=("$branch_name_that_matches")
        ((i++))
    done
    for commit_hash_that_matches in "${commit_hashes_that_match[@]}"; do
        echo "  $i) [commit] $commit_hash_that_matches" >&2
        options+=("$commit_hash_that_matches")
        ((i++))
    done
    [[ ${#options[@]} -eq 0 ]] && { echo "No matches found" >&2; return 1; }
    local choice
    read "choice?Select: "
    [[ -z "$choice" || ! "$choice" =~ ^[0-9]+$ || $choice -lt 1 || $choice -gt ${#options[@]} ]] && { echo "Cancelled" >&2; return 1; }
    echo "${options[$choice]}"
}

function GET_GIT_LOG_COUNT() {
    local log_display_count=$GIT_LOG_COUNT
    local number_of_commits_ahead_of_remote
    if [[ -n "$1" ]]; then
        number_of_commits_ahead_of_remote=$(git -C "$1" rev-list --count origin/$(git -C "$1" rev-parse --abbrev-ref HEAD)..HEAD 2>/dev/null)
    else
        number_of_commits_ahead_of_remote=$(git rev-list --count origin/$(git rev-parse --abbrev-ref HEAD)..HEAD 2>/dev/null)
    fi
    (( number_of_commits_ahead_of_remote >= log_display_count )) && log_display_count=$((number_of_commits_ahead_of_remote + 1))
    echo $log_display_count
}

