# tmux open brain parent
function TOBP() {
    if [[ $# -eq 0 ]]; then
        CDBP || return 1
        local left_pane_id="$TMUX_PANE"
        tmux send-keys -t "$left_pane_id" 'NOTAR' Enter
        tmux send-keys -t "$left_pane_id" 'AIR' Enter
        local right_pane_id=$(tmux split-window -h -t "$left_pane_id" -P -F '#{pane_id}')
        tmux send-keys -t "$right_pane_id" 'VB' Enter
        tmux split-window -v -t "$left_pane_id" -l 8%
        tmux split-window -v -t "$right_pane_id"
        tmux select-pane -t "$right_pane_id"
    else
        local dir
        for dir in "${(Oa)@}"; do
            local pane_id=$(tmux new-window -a -d -c "$dir" -P -F '#{pane_id}')
            tmux send-keys -t "$pane_id" 'TOBP' Enter
        done
    fi
}

