function GCH() {
    local branch branch_name_that_matches commit_hash_that_matches file_path
    if [[ $# -eq 0 ]]; then
        read "branch?Branch/Commit: "
        [[ -z "$branch" ]] && { echo "Branch required"; return 1; }
        [[ "$branch" == -* ]] && { echo "Invalid branch name"; return 1; }
        if git show-ref --verify --quiet "refs/heads/$branch"; then
            git checkout "$branch"
        elif git rev-parse --verify "$branch^{commit}" >/dev/null 2>&1; then
            git checkout "$branch"
        else
            local branch_names_that_match=($(git branch --list "*$branch*" --format='%(refname:short)'))
            local commit_hashes_that_match=($(git log --all --oneline 2>/dev/null | awk '{print $1}' | grep "^$branch"))
            echo "No exact match. Options:"
            local i=1
            local options=()
            for branch_name_that_matches in "${branch_names_that_match[@]}"; do
                echo "  $i) [branch] $branch_name_that_matches"
                options+=("branch:$branch_name_that_matches")
                ((i++))
            done
            for commit_hash_that_matches in "${commit_hashes_that_match[@]}"; do
                echo "  $i) [commit] $commit_hash_that_matches"
                options+=("commit:$commit_hash_that_matches")
                ((i++))
            done
            echo "  $i) [new branch] $branch"
            options+=("new:$branch")
            local choice
            read "choice?Select: "
            [[ -z "$choice" || ! "$choice" =~ ^[0-9]+$ || $choice -lt 1 || $choice -gt ${#options[@]} ]] && { echo "Cancelled"; return 1; }
            local selected_option="${options[$choice]}"
            case "$selected_option" in
                branch:*) git checkout "${selected_option#branch:}" ;;
                commit:*) git checkout "${selected_option#commit:}" ;;
                new:*)    git checkout -b "${selected_option#new:}" ;;
            esac
        fi
    else
        read "branch?Branch: "
        [[ -z "$branch" ]] && { echo "Branch required"; return 1; }
        [[ "$branch" == -* ]] && { echo "Invalid branch name"; return 1; }
        for file_path in "$@"; do
            PRINT_AS_HEADER "$file_path"
            if git -C "$file_path" show-ref --verify --quiet "refs/heads/$branch"; then
                git -C "$file_path" checkout "$branch"
            else
                git -C "$file_path" checkout -b "$branch"
            fi
        done
    fi
}

