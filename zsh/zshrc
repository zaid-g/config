#  %% --- [tar] ---:

function TARGZ() {
    local target_path="${1:-.}"
    local full_file_path
    full_file_path="$(readlink -f "$target_path")"

    [[ ! -e "$full_file_path" ]] && { echo "Error: '$target_path' does not exist"; return 1; }

    local file_name
    file_name="$(basename "$full_file_path")"
    local tmp_output_file_path="$HOME/${file_name}.tar.gz"
    local final_output_file_path="$PWD/${file_name}.tar.gz"

    [[ -e "$final_output_file_path" ]] && { echo "Error: '$final_output_file_path' already exists"; return 1; }
    [[ -e "$tmp_output_file_path" ]] && { echo "Error: '$tmp_output_file_path' already exists"; return 1; }

    tar -czf "$tmp_output_file_path" -C "$(dirname "$full_file_path")" "$file_name" && mv "$tmp_output_file_path" "$final_output_file_path" && readlink -f "$final_output_file_path"
}

function UNTARGZ() {
    local archive_path="$1"
    [[ -z "$archive_path" ]] && { echo "Usage: UNTARGZ <archive.tar.gz>"; return 1; }
    [[ ! -f "$archive_path" ]] && { echo "Error: '$archive_path' does not exist or is not a file"; return 1; }
    local full_file_path
    full_file_path="$(readlink -f "$archive_path")"
    tar -xzf "$full_file_path" -C "$PWD"
}

