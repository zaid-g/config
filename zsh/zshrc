#  %% -------- [files folders path management] ----------:

function CLEAN_FILENAME() {
    echo -n "$1" | perl -CSD -pe 's/[\/:@%,=\s\x{00a0}\x{202f}\x{2007}\x{2009}\x{200a}\x{205f}\x{3000}]/-/g' | tr -d '*?[]|&;<>$`!"'"'"'(){}^~#\\'
}

function PROCESS_DOWNLOAD_FILES_PATHS() {
    local prefix_to_add_to_file_name="" file_count=1 file_name downloads_file_path cleaned_filename destination_filename
    if [[ "$1" =~ ^[0-9]+$ ]] && [[ -n "$2" ]]; then
        file_count="$1"; prefix_to_add_to_file_name="$2"
    elif [[ "$1" =~ ^[0-9]+$ ]]; then
        file_count="$1"
    elif [[ -n "$1" ]]; then
        prefix_to_add_to_file_name="$1"
    fi
    local actual_file_count=$(ls ~/Downloads 2>/dev/null | wc -l | tr -d ' ')
    (( file_count > actual_file_count )) && file_count=$actual_file_count
    local file_names_in_downloads=$(ls -Art ~/Downloads 2>/dev/null | tail -n $file_count)
    [[ -z "$file_names_in_downloads" ]] && { echo "No files found" >&2; return 1; }
    echo "$file_names_in_downloads" | while IFS= read -r file_name; do
        downloads_file_path="$HOME/Downloads/$file_name"
        cleaned_filename=$(CLEAN_FILENAME "$file_name")
        destination_filename="${prefix_to_add_to_file_name:+${prefix_to_add_to_file_name}_}$cleaned_filename"
        echo "$downloads_file_path|$destination_filename"
    done
}

function GENERATE_PRONOUNCEABLE_STRING() {
    local string_target_length=${1:-8}
    local consonant_pool="bcdfghjklmnpqrstvwxyz"
    local vowel_pool="aeiou"
    local generated_string=""
    local i byte
    for ((i=0; i<string_target_length; i++)); do
        byte=$(od -An -tu1 -N1 /dev/urandom)
        if (( i % 2 == 0 )); then
            generated_string+=${consonant_pool:$((byte % ${#consonant_pool})):1}
        else
            generated_string+=${vowel_pool:$((byte % ${#vowel_pool})):1}
        fi
    done
    echo "$generated_string"
}

function CREATE_TIMESTAMPED_DIR_AND_CD() {
    local parent_folder_path="$1"
    shift
    local raw_folder_name="${*:-$(GENERATE_PRONOUNCEABLE_STRING 8)}"
    local cleaned_folder_name=$(CLEAN_FILENAME "$raw_folder_name")
    local timestamped_dir_path="${parent_folder_path:+$parent_folder_path/}${cleaned_folder_name}-$(date +%Y_%m_%d-%H_%M_%S)"
    mkdir -p "$timestamped_dir_path" && cd "$timestamped_dir_path"
}

function LLD() {
    local display_count=${1:-5}
    local total_file_count=$(ls ~/Downloads | wc -l | tr -d ' ')
    (( total_file_count > display_count )) && echo "..."
    ls -ltr --color=auto ~/Downloads/ | tail -n $display_count
}

