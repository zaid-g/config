# grep in files (last arg is pattern, preceding args are extensions)
function RG() {
    if [ "$#" -eq 1 ]; then
        rg "$1"
    else
        local ext pattern="${@: -1}"
        local type_flags=()
        for ext in "${@:1:$#-1}"; do
            type_flags+=("-g" "*.${ext}")
        done
        rg "${type_flags[@]}" "$pattern"
    fi
}

function FDBANY() {
    echo
    local pattern=$(IFS='|'; echo "$*")
    local exclude_flags=()
    local excluded_pattern
    for excluded_pattern in "${GITIGNORE_PATTERNS[@]}"; do
        exclude_flags+=("--glob" "!**/$excluded_pattern/**")
    done
    rg -l --no-ignore --max-filesize 50M "$pattern" --glob '**/brain/**' "${exclude_flags[@]}" .
}

function FDBALL() {
    echo
    local exclude_flags=()
    local excluded_pattern
    for excluded_pattern in "${GITIGNORE_PATTERNS[@]}"; do
        exclude_flags+=("--glob" "!**/$excluded_pattern/**")
    done
    local file_paths_that_matched_patterns_so_far=$(rg -l --no-ignore --max-filesize 50M "$1" --glob '**/brain/**' "${exclude_flags[@]}" .)
    shift
    local pattern
    for pattern in "$@"; do
        [ -z "$file_paths_that_matched_patterns_so_far" ] && return
        file_paths_that_matched_patterns_so_far=$(echo "$file_paths_that_matched_patterns_so_far" | tr '\n' '\0' | xargs -0 rg -l --no-ignore --max-filesize 50M "$pattern")
    done
    [ -z "$file_paths_that_matched_patterns_so_far" ] && return
    echo "$file_paths_that_matched_patterns_so_far"
}

