#  %% -------- [remote] ----------:

function SSH() {
    local forwarded_ports=()
    local forwarded_port
    for forwarded_port in "$@"; do
        [[ "$forwarded_port" =~ ^[0-9]+$ ]] || { echo "Usage: SSH [port]..."; return 1; }
        forwarded_ports+=("-L" "${forwarded_port}:localhost:${forwarded_port}")
    done
    ssh "${forwarded_ports[@]}" "$REMOTE"
}

# upload Downloads content to remote
# (from local Downloads to remote Downloads)
function UD() {
    local downloads_file_path destination_filename
    ssh "$REMOTE" "mkdir -p ~/Downloads"
    PROCESS_DOWNLOAD_FILES_PATHS "$@" | while IFS='|' read -r downloads_file_path destination_filename; do
        [ -e "$downloads_file_path" ] && rsync -avz "$downloads_file_path" "$REMOTE:~/Downloads/$destination_filename"
    done
}

# upload local filesystem content to remote Downloads
function U() {
    local file_path
    if [ $# -eq 0 ]; then
        echo "Usage: U <path>..."
        return 1
    fi
    ssh "$REMOTE" "mkdir -p ~/Downloads"
    local full_file_paths=()
    for file_path in "$@"; do
        full_file_paths+=($(readlink -f "$file_path"))
    done
    rsync -avz "${full_file_paths[@]}" "$REMOTE:~/Downloads/"
}

# download from remote (remote filesystem to local Downloads)
function D() {
    local remote_file_path
    [[ $# -eq 0 ]] && { echo "Usage: D <remote_file_path>..."; return 1; }
    [[ -z "$REMOTE" ]] && { echo "Error: REMOTE environment variable must be set"; return 1; }
    for remote_file_path in "$@"; do
        if rsync -rvz "$REMOTE:$remote_file_path" ~/Downloads/; then
            local downloaded_file_name=$(basename "$remote_file_path")
            chmod -R u+w ~/Downloads/${~downloaded_file_name}
            echo "✅ rsync succeeded for $REMOTE:$remote_file_path"
        else
            echo "❌ rsync failed for $REMOTE:$remote_file_path"
        fi
    done
}

# download from Remote's Downloads
# (remote Downloads to local Downloads)
function DD() {
    if [ -z "$REMOTE" ]; then
        echo "Error: REMOTE environment variable must be set"
        return 1
    fi
    local latest_file_in_remote_downloads=$(ssh "$REMOTE" "ls -Art ~/Downloads 2>/dev/null | tail -n 1")
    if [ -z "$latest_file_in_remote_downloads" ]; then
        echo "❌ No files found in remote Downloads"
        return 1
    fi
    if rsync -avz "$REMOTE:~/Downloads/$latest_file_in_remote_downloads" ~/Downloads/; then
        chmod -R u+w ~/Downloads/"$latest_file_in_remote_downloads"
        echo "✅ Downloaded to: ~/Downloads/$latest_file_in_remote_downloads"
    else
        echo "❌ rsync failed for $REMOTE:~/Downloads/$latest_file_in_remote_downloads"
        return 1
    fi
}

