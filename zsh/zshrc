#  %% -------- [sleep management caff nocaff driving mode] ----------:

function CAFF() {
    if [[ "$OSTYPE" == "darwin"* ]]
    then
        caffeinate -dimsu -t 7200 &
        echo "Caffeinate started for 2h (PID: $!)"
    else
        systemd-inhibit --what=idle:sleep:handle-lid-switch --who="Manual" --why="User requested" --mode=block sleep 7200 &> /dev/null &
        echo "Sleep inhibited for 2h (PID: $!)"
    fi
}

function NOCAFF() {
    if [[ "$OSTYPE" == "darwin"* ]]
    then
        pkill caffeinate && echo "Killed caffeinate" || echo "No caffeinate process found"
    else
        pkill -f "systemd-inhibit.*who=Manual" && echo "Sleep inhibitor killed" || echo "No sleep inhibitor found"
    fi
}

