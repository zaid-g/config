function FIND_BRAIN_PARENT_PATH() {
    local folder_path="$PWD"
    while [[ "$folder_path" != "/" ]]; do
        if [[ -d "$folder_path/brain" ]]; then
            echo "$folder_path"
            return 0
        fi
        folder_path="$(dirname "$folder_path")"
    done
    echo "No 'brain' directory found searching up to filesystem root" >&2
    return 1
}

function FIND_BRAIN_PARENT_NAME() {
    local brain_parent_path
    brain_parent_path=$(FIND_BRAIN_PARENT_PATH) || return 1
    basename "$brain_parent_path"
}

